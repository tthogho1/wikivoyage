# Copy this file to .env and fill in your values.
# .env is NOT committed to version control.

# ----- Zilliz Cloud -----
ZILLIZ_URI=https://xxxx.zillizcloud.com
ZILLIZ_TOKEN=<your-api-key>

# ----- Pipeline (optional, shown with defaults) -----
WIKIVOYAGE_PAGES_DIR=pages
ZILLIZ_COLLECTION=wikivoyage_pages
ZILLIZ_BATCH_SIZE=32

# ----- BGE-M3 device (optional) -----
# cpu | cuda | mps
BGE_M3_DEVICE=cpu
# Set to 1 to enable fp16 (only on GPU)
BGE_M3_USE_FP16=0
